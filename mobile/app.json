{
  "expo": {
    "name": "Deal&Co",
    "slug": "dealandco",
    "scheme": "dealandco",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.dealandcompany.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "fr.dealandcompany.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications"
    ],
    "extra": {
      "apiBaseUrl": "https://www.dealandcompany.fr"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
