{
  "expo": {
    "name": "Deal&Co",
    "slug": "dealandco",
    "scheme": "dealandco",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2f6fb8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.dealandcompany.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "fr.dealandcompany.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2f6fb8"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-notifications", { "icon": "./assets/icon.png", "color": "#2f6fb8" }],
      ["expo-splash-screen", { "image": "./assets/splash.png", "backgroundColor": "#2f6fb8" }]
    ],
    "extra": {
      "apiBaseUrl": "https://www.dealandcompany.fr"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
