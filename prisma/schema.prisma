generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                    @id @default(cuid())
  email                   String                    @unique
  password                String
  name                    String
  avatar                  String?
  verified                Boolean                   @default(false)
  memberSince             Int                       @default(2024)
  createdAt               DateTime                  @default(now())
  role                    String                    @default("USER")
  adminNote               String?
  participants            ConversationParticipant[]
  listings                Listing[]
  sentMessages            Message[]                 @relation("SentMessages")
  favorites               Favorite[]
  savedSearches           SavedSearch[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  isPro                   Boolean                   @default(false)
  siret                   String?                   @unique
  companyName             String?
  lastLoginAt             DateTime?
  reengagementSentAt      DateTime?
  earlyAdopterDiscount    Boolean                   @default(false)
  bannedAt                DateTime?
  banReason               String?
  restrictedAt            DateTime?
  spamScore               Int                       @default(0)
  apiKeys                 ApiKey[]
  consentGivenAt          DateTime?
  marketingConsent        Boolean                   @default(false)

  // Trust & safety
  trustScore           Int      @default(50)
  trustScoreUpdatedAt  DateTime @default(now())
  emailVerified        Boolean  @default(false)
  phoneNumber          String?
  phoneVerified        Boolean  @default(false)
  totalReportsAgainst  Int      @default(0)
  rejectedListingCount Int      @default(0)

  reportsMade      Report[]          @relation("ReportReporter")
  reportsAgainst   Report[]          @relation("ReportSubject")
  moderationEvents ModerationEvent[]
  deviceSessions   DeviceSession[]
  rateLimitBuckets RateLimitBucket[]
  externalSources  ExternalSource[]

  // Deal&Co Pet
  petProService PetProService?
  petBookings   PetBooking[]   @relation("PetBookingClient")
  petReviews    PetReview[]    @relation("PetReviewAuthor")
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EarlyAdopter {
  id               String    @id @default(cuid())
  companyName      String
  siret            String?
  managerFirstName String
  email            String    @unique
  registeredAt     DateTime  @default(now())
  claimedAt        DateTime?
  userId           String?
}

model Waitlist {
  id              String   @id @default(cuid())
  email           String
  citySlug        String?
  categoryId      String?
  subcategorySlug String?
  source          String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@unique([email, categoryId, citySlug, subcategorySlug])
  @@index([email])
  @@index([categoryId])
  @@index([citySlug])
}

model Listing {
  id                  String    @id @default(cuid())
  title               String
  description         String
  price               Float
  category            String
  subcategory         String?
  location            String
  condition           String    @default("Good")
  brand               String?
  material            String?
  images              String    @default("[]")
  isPremium           Boolean   @default(false)
  isVerified          Boolean   @default(false)
  userId              String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  metadata            String    @default("{}")
  vehicleKm           Int?
  vehicleYear         Int?
  immoSurface         Float?
  immoRooms           Int?
  phone               String?
  phoneHash           String?
  hidePhone           Boolean   @default(false)
  status              String    @default("APPROVED")
  rejectionReason     String?
  adminNote           String?
  expiresAt           DateTime?
  expiryNotifiedAt    DateTime?
  photoReminderSentAt DateTime?
  viewCount           Int       @default(0)
  shadowBanned        Boolean   @default(false)
  reviewPriority      Int       @default(0)

  // Trust & safety
  qualityScore          Int      @default(50)
  qualityScoreUpdatedAt DateTime @default(now())
  reportCount           Int      @default(0)
  imageDupCount         Int      @default(0)
  ipAtCreate            String?
  uaAtCreate            String?
  flagsJson             String   @default("[]")

  // Risk engine — empreinte SimHash (hex 16 car.) + bandes LSH + score de risque
  simhash       String?
  lshBand0      Int?
  lshBand1      Int?
  lshBand2      Int?
  lshBand3      Int?
  riskScore     Int     @default(0)
  riskDecision  String?

  conversations    Conversation[]
  user             User              @relation(fields: [userId], references: [id])
  favorites        Favorite[]
  listingImages    ListingImage[]
  reports          Report[]
  moderationEvents ModerationEvent[]

  @@index([status, deletedAt, shadowBanned])
  @@index([qualityScore])
  @@index([lshBand0])
  @@index([lshBand1])
  @@index([lshBand2])
  @@index([lshBand3])
  @@index([phoneHash])
}

model ListingImage {
  id           String   @id @default(cuid())
  listingId    String
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url          String
  phash        BigInt?
  width        Int?
  height       Int?
  sizeBytes    Int?
  blurVar      Float?
  isScreenshot Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([phash])
  @@index([listingId])
}

model Report {
  id         String    @id @default(cuid())
  listingId  String?
  userId     String?
  reporterId String
  category   String // scam, spam, illegal, offensive, fake, wrong_category, duplicate, personal_data, stolen_photos, other
  message    String?
  status     String    @default("OPEN") // OPEN, RESOLVED, DISMISSED
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())

  reporter User     @relation("ReportReporter", fields: [reporterId], references: [id])
  subject  User?    @relation("ReportSubject", fields: [userId], references: [id])
  listing  Listing? @relation(fields: [listingId], references: [id])

  @@index([listingId, status])
  @@index([userId, status])
  @@index([reporterId, createdAt])
  @@index([status, createdAt])
}

model ModerationEvent {
  id          String   @id @default(cuid())
  listingId   String?
  userId      String?
  actor       String // "system", "admin:{id}", "cron:{name}"
  action      String // auto_approve, auto_pending, auto_shadow, auto_reject, admin_approve, report_flagged, rate_limit_hit, etc
  reason      String
  flagsJson   String   @default("[]")
  scoreBefore Int?
  scoreAfter  Int?
  createdAt   DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  listing Listing? @relation(fields: [listingId], references: [id])

  @@index([listingId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model DeviceSession {
  id          String   @id @default(cuid())
  userId      String
  ipHash      String
  uaHash      String
  fingerprint String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([ipHash])
  @@index([fingerprint])
  @@index([userId])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  userId      String?
  ipHash      String?
  bucket      String // listing_create, message_send, image_upload, report_submit, signup
  count       Int      @default(1)
  windowStart DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])

  @@unique([userId, bucket, windowStart])
  @@index([ipHash, bucket])
  @@index([userId, bucket])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Conversation {
  id           String                    @id @default(cuid())
  listingId    String
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  listing      Listing                   @relation(fields: [listingId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  userId         String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([userId, conversationId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  senderId       String
  conversationId String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  riskScore      Int          @default(0)
  flagged        Boolean      @default(false)
  flagReason     String?
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([flagged, createdAt])
}

model ExternalSource {
  id           String    @id @default(cuid())
  ownerId      String
  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  label        String // nom public affiché sur les annonces importées
  kind         String    @default("auto") // bsk | auto | (futurs connecteurs)
  url          String // URL complète saisie (= base_url scrapée)
  domain       String? // hostname extrait (sans www) — ex. bskimmobilier.com
  agencySlug   String? // premier segment de path — ex. paris-17 ou sylvie-mekil-8374
  active       Boolean   @default(true)
  lastSyncedAt DateTime?
  lastResult   String? // JSON: { created, deduped, failed, total, details[] }
  createdAt    DateTime  @default(now())

  @@index([ownerId])
  @@index([domain, agencySlug])
}

model Blacklist {
  kind    String // domain | email_domain | phone | ip
  value   String
  reason  String?
  source  String? // ex. "discord-antiscam", "manual"
  addedAt DateTime @default(now())

  @@id([kind, value])
  @@index([kind])
}

model SavedSearch {
  id             String   @id @default(cuid())
  userId         String
  name           String
  filters        String   @default("{}") // JSON: { category, q, minPrice, maxPrice, location, ... }
  lastNotifiedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HeroBanner {
  id        String    @id @default(cuid())
  title     String
  subtitle  String?
  bgFrom    String    @default("#2f6fb8")
  bgTo      String    @default("#1a5a9e")
  bgImage   String?
  textColor String    @default("#ffffff")
  isActive  Boolean   @default(false)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
}

model CategorySetting {
  id           String   @id @default(cuid())
  categoryId   String   @unique
  approvalMode String   @default("AUTO") // "AUTO" | "MANUAL"
  updatedAt    DateTime @updatedAt
}

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  createdAt DateTime @default(now())
}

model Advertisement {
  id             String    @id @default(cuid())
  title          String
  description    String
  imageUrl       String
  imageUrlWide   String?
  destinationUrl String
  isActive       Boolean   @default(true)
  clicks         Int       @default(0)
  impressions    Int       @default(0)
  // Impressions par emplacement
  impCarousel    Int       @default(0) // Bannière accueil
  impRotator     Int       @default(0) // Encart page annonce
  impGrid        Int       @default(0) // Fil de résultats
  scheduledAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
}

model SeoPageContent {
  id              String   @id @default(cuid())
  pageKey         String   @unique
  categoryId      String
  subcategorySlug String?
  citySlug        String?
  metaTitle       String
  metaDescription String
  h1              String
  intro           String
  localTips       String?
  faq             String   @default("[]")
  keywords        String   @default("[]")
  model           String   @default("claude")
  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([categoryId])
  @@index([citySlug])
  @@index([categoryId, citySlug])
}

// ─────────────────────────────────────────────────────────────────────────────
// Deal&Co Pet — paid pet-services matching (separate universe, 10% commission)
// ─────────────────────────────────────────────────────────────────────────────

model PetProService {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String
  slug        String  @unique
  bio         String
  city        String
  postalCode  String?
  photos      String  @default("[]")

  stripeAccountId      String?  @unique
  stripeChargesEnabled Boolean  @default(false)
  stripePayoutsEnabled Boolean  @default(false)
  kycCompletedAt       DateTime?

  isPublished Boolean @default(false)
  isVerified  Boolean @default(false)
  avgRating   Float?
  reviewCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offerings PetServiceOffering[]
  bookings  PetBooking[]
  reviews   PetReview[]

  @@index([city])
  @@index([isPublished, kycCompletedAt])
}

model PetServiceOffering {
  id           String        @id @default(cuid())
  proServiceId String
  proService   PetProService @relation(fields: [proServiceId], references: [id], onDelete: Cascade)

  serviceType String // GARDE_DOMICILE | GARDE_CHEZ_PRO | PROMENADE
  title       String
  description String
  priceCents  Int
  unit        String  @default("DAY") // DAY | HOUR
  petTypes    String  @default("[\"DOG\"]")
  maxPets     Int     @default(1)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings PetBooking[]

  @@index([proServiceId, isActive])
  @@index([serviceType])
}

model PetBooking {
  id String @id @default(cuid())

  proServiceId String
  proService   PetProService @relation(fields: [proServiceId], references: [id])

  offeringId String
  offering   PetServiceOffering @relation(fields: [offeringId], references: [id])

  clientId String
  client   User   @relation("PetBookingClient", fields: [clientId], references: [id])

  startDate DateTime
  endDate   DateTime
  petCount  Int      @default(1)
  petInfo   String?

  totalCents       Int
  platformFeeCents Int
  proPayoutCents   Int

  // PENDING | CONFIRMED | IN_PROGRESS | COMPLETED | CANCELLED | REFUNDED
  status String @default("PENDING")

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  cancelledAt  DateTime?
  cancelReason String?

  payment PetPayment?
  review  PetReview?

  @@index([clientId])
  @@index([proServiceId, status])
  @@index([status, endDate])
}

model PetPayment {
  id        String     @id @default(cuid())
  bookingId String     @unique
  booking   PetBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  stripePaymentIntentId String  @unique
  stripeChargeId        String?
  stripeTransferId      String?
  stripeRefundId        String?

  amountCents      Int
  platformFeeCents Int
  currency         String @default("eur")

  // REQUIRES_PAYMENT | SUCCEEDED | HELD | RELEASED | REFUNDED | FAILED
  status String @default("REQUIRES_PAYMENT")

  capturedAt DateTime?
  releasedAt DateTime?
  refundedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model PetReview {
  id        String     @id @default(cuid())
  bookingId String     @unique
  booking   PetBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  proServiceId String
  proService   PetProService @relation(fields: [proServiceId], references: [id])

  authorId String
  author   User   @relation("PetReviewAuthor", fields: [authorId], references: [id])

  rating  Int
  comment String?

  createdAt DateTime @default(now())

  @@index([proServiceId])
}
